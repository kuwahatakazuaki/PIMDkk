$The Number of Proccesors
1
$Ndim
1
$Nbead
24
$temperature
300.0
$Nstep
2000
$dt               # Time stpe (fs)
0.1
$Isimulation      # 0:PIMD, 1:RPMD, 2:CMD, 3:PIHMC, 10:CLMD (For classical, just set Nbead=1)
0
$out_step         # Output per out_step
5
$Ncent            # Method of Centroid NHC, 0: NVE, 3: NVT
3
$Lrestart
.F.
$Iforce           # 1:MOPAC, 6:Gaussian, 8:VASP, 9:SIESTA, 15:Harmonic, 16:Double Morse 31:Water(SPC/F2)
11
$address_result   # Result directory
./Result
$address_scr      # Scretch directory
./Scr
$seed             # random number seed, Need only one integer
101
$Langstrom        # Coordinate in Angstrom (True of False)
.T.
$Lrandom_coor     # Random intial coordinate (True of False)
.F.
$Lperiodic        # Periodic boundary condition (True of False)
.F.
$lattice
17.0    0.0    0.0
 0.0   17.0    0.0
 0.0    0.0   17.0

$Lsave_charge     # Save charge (True of False)
.F.
$Lsave_hfcc       # Save HFCC (True of False)
.F.
$Lsave_dipole     # Save dipole moment (True of False)
.F.
$Lsave_force      # Save force (True of False)
.F.
$Lsave_energy     # Save force (True of False)
.F.
$version
g16
$Nref             # time deconposition for reversible RESPA
5
$Nys              # Deconposition of thermostat. chose 1 or 3 or 5
5
$Nnhc
4
$gamma
1.0

$Icons            # Constraint type, 0:off, 1:bead-average bond distance
1
$cons_atom1       # First constrained atom index
1
$cons_atom2       # Second constrained atom index
2
$cons_atom3       # Reserved for future constraint types; unused for Icons=1
3
$cons_val         # Target bead-average distance in Angstrom
0.74d0
$cons_strength    # Harmonic force constant in Hartree/bohr^2
5.0d0

$Lexit            # Exit the program (True of False)
.F.
$end parameter

$Coords
H    0.0    0.0   0.0
